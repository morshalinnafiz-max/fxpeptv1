<%- include('partials/header', { title: 'Checkout' }) %>

<div class="page-header">
  <h1>Checkout</h1>
  <p>Review and confirm your order</p>
</div>

<div style="max-width:820px;margin:2.5rem auto;padding:0 2rem">
  <div class="checkout-steps" style="margin-bottom:2.5rem">
    <div class="step active"><div class="step-num">1</div>&nbsp;Review</div>
    <div class="step-connector"></div>
    <div class="step active"><div class="step-num">2</div>&nbsp;Confirm</div>
    <div class="step-connector"></div>
    <div class="step"><div class="step-num">3</div>&nbsp;Pay</div>
  </div>

  <div class="checkout-grid" style="display:grid;grid-template-columns:1fr 320px;gap:2rem;align-items:start">
    <div>
      <div style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;margin-bottom:1.5rem">
        <div style="background:#f8fafc;padding:1rem 1.4rem;border-bottom:1px solid #e2e8f0;font-weight:700;color:#0d2044">
          &#128230; Your Order
        </div>
        <% cart.forEach(function(item) { %>
          <div style="display:flex;align-items:center;gap:1rem;padding:1rem 1.4rem;border-bottom:1px solid #f1f5f9">
            <div style="width:60px;height:60px;background:#f8fafc;border-radius:8px;overflow:hidden;flex-shrink:0">
              <img src="/images/<%= item.image %>" alt="<%= item.name %>" style="width:100%;height:100%;object-fit:contain;padding:.3rem" />
            </div>
            <div style="flex:1">
              <div style="font-weight:600;color:#0a1628"><%= item.name %></div>
              <div style="font-size:.82rem;color:#94a3b8"><%= item.strength %> &middot; Qty: <%= item.quantity %></div>
            </div>
            <div style="font-weight:700;color:#1d4ed8">$<%= (item.price * item.quantity).toFixed(2) %></div>
          </div>
        <% }); %>
        <div style="padding:1rem 1.4rem;display:flex;justify-content:space-between;font-weight:800;font-size:1.1rem;color:#0a1628">
          <span>Total (CAD)</span>
          <span>$<%= total.toFixed(2) %></span>
        </div>
      </div>

      <div class="payment-box" style="margin-bottom:1.5rem">
        <h3>&#128179; How to Pay</h3>
        <div class="pay-email">info@fxpept.ca</div>
        <p>After placing your order, send exactly <strong>$<%= total.toFixed(2) %> CAD</strong> via Interac e-Transfer to <strong>info@fxpept.ca</strong>. Include your order number in the message. Orders processed within 24hrs of confirmed payment.</p>
      </div>

      <form action="/checkout" method="POST">
        <div class="form-group">
          <label>Order Notes (optional)</label>
          <textarea name="notes" placeholder="Shipping address, special instructions..."></textarea>
        </div>
        <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:.9rem 1rem;font-size:.82rem;color:#1d4ed8;margin-bottom:1.5rem;line-height:1.6">
          &#10003; By placing this order I confirm these products are for <strong>research purposes only</strong>.
        </div>
        <button type="submit" class="btn btn-primary btn-full btn-lg">
          &#10003; Place Order &mdash; $<%= total.toFixed(2) %> CAD
        </button>
      </form>
    </div>

    <div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:1.5rem;position:sticky;top:88px">
      <h3 style="font-size:1rem;margin-bottom:1rem;color:#0d2044">Your Account</h3>
      <div style="font-size:.88rem;font-weight:700;color:#0a1628;margin-bottom:.3rem"><%= user.name %></div>
      <div style="font-size:.82rem;color:#94a3b8;margin-bottom:1.5rem"><%= user.email %></div>
      <div style="border-top:1px solid #f1f5f9;padding-top:1rem;display:flex;flex-direction:column;gap:.8rem">
        <div class="trust-item">
          <div class="trust-icon">&#128274;</div>
          <div class="trust-text"><strong>Secure Order</strong><span>Encrypted &amp; Private</span></div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128666;</div>
          <div class="trust-text"><strong>Canadian Shipping</strong><span>Domestic only</span></div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128203;</div>
          <div class="trust-text"><strong>Track Orders</strong><span>Via your dashboard</span></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>@media(max-width:700px){.checkout-grid{grid-template-columns:1fr !important}}</style>

<%- include('partials/footer') %>
