<%- include('partials/header', { title: 'Order Confirmed' }) %>

<div class="confirmation-page">
  <div class="confirmation-icon">&#10003;</div>
  <h1>Order Placed!</h1>
  <p>Your order <strong><%= order.order_number %></strong> has been received. Please send your e-transfer to complete the process.</p>

  <div class="confirmation-box">
    <div style="text-align:center;margin-bottom:1.5rem">
      <div style="font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#64748b;margin-bottom:.3rem">Order Number</div>
      <div style="font-size:1.6rem;font-weight:900;color:#0d2044"><%= order.order_number %></div>
    </div>

    <div class="payment-box">
      <h3>&#128179; Send Payment Now</h3>
      <div class="pay-email">info@fxpept.ca</div>
      <p>Send exactly <strong>$<%= order.total.toFixed(2) %> CAD</strong> via Interac e-Transfer. Put <strong><%= order.order_number %></strong> in the message/memo field. Your order ships after payment is confirmed (within 24hrs).</p>
    </div>

    <div style="margin-top:1.5rem">
      <div style="font-weight:700;color:#0d2044;margin-bottom:.8rem;font-size:.9rem">ORDER ITEMS</div>
      <% order.items.forEach(function(item) { %>
        <div style="display:flex;justify-content:space-between;padding:.4rem 0;font-size:.88rem;border-bottom:1px solid #f1f5f9">
          <span style="color:#1e293b"><%= item.name %> <%= item.strength %> &times; <%= item.quantity %></span>
          <span style="font-weight:700;color:#1d4ed8">$<%= (item.price * item.quantity).toFixed(2) %></span>
        </div>
      <% }); %>
      <div style="display:flex;justify-content:space-between;padding:.8rem 0 0;font-weight:800;font-size:1rem;color:#0a1628">
        <span>Total (CAD)</span>
        <span>$<%= order.total.toFixed(2) %></span>
      </div>
    </div>
  </div>

  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
    <a href="/orders" class="btn btn-primary">Track My Orders</a>
    <a href="/products" class="btn btn-outline-blue">Continue Shopping</a>
  </div>
</div>

<%- include('partials/footer') %>
