  </div>
</div>

<!-- ═══════════════════ FEATURED PRODUCTS ═══════════════════ -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Best Sellers</div>
      <h2>Top Research Compounds</h2>
      <p>Most popular peptides trusted by labs across Canada</p>
    </div>
    <div class="products-grid">
      <% featured.forEach(function(p, i) { %>
        <div class="product-card reveal reveal-delay-<%= (i % 5) + 1 %>">
          <% if (p.badge) { %><div class="product-card-badge"><%= p.badge %></div><% } %>
          <a href="/product/<%= p.slug %>">
            <div class="product-card-img">
              <img src="/images/<%= p.image %>" alt="<%= p.name %>" loading="lazy" />
            </div>
          </a>
          <div class="product-card-body">
            <div class="product-card-cat"><%= p.category %></div>
            <div class="product-card-name"><%= p.name %></div>
            <div class="product-card-strength"><%= p.strength %></div>
            <div class="product-card-purity">✓ <%= p.purity %> Purity</div>
            <div class="product-card-footer">
              <div class="product-card-price"><sup>$</sup><%= p.price %></div>
              <button class="btn-add-cart" data-id="<%= p.id %>">+ Cart</button>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
    <div style="text-align:center;margin-top:2.5rem" class="reveal">
      <a href="/products" class="btn btn-primary btn-lg">View All 52 Products →</a>
    </div>
  </div>
</section>

